# pacer-ai environment configuration
# Copy to .env and fill values

# Database
DATABASE_URL=sqlite:///./pacer.db

# LLM — set LLM_PROVIDER=openai-compat for proxies like ff-router
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_BASE_URL=
PACER_MAIN_MODEL=claude-sonnet-4-6
PACER_ROUTER_MODEL=claude-haiku-4-5-20251001

# Server
PACER_HOST=127.0.0.1
PACER_PORT=8000

# Internal service token (for scheduler → API communication)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PACER_INTERNAL_TOKEN=

# Auth
PACER_PIN_LENGTH=6
# Session token TTL — default 7 days
PACER_TOKEN_TTL_SECONDS=604800
# Login lockout: N failed PIN tries → locked for M seconds
PACER_LOGIN_MAX_ATTEMPTS=5
PACER_LOGIN_LOCKOUT_SECONDS=300

# CORS — comma-separated browser origins (empty = localhost:5173 dev defaults)
PACER_CORS_ORIGINS=

# Uploads
PACER_UPLOAD_MAX_BYTES=10485760

# Memory summarization: run the LLM extractor every Nth assistant turn
PACER_MEMORY_SUMMARIZE_INTERVAL=3
